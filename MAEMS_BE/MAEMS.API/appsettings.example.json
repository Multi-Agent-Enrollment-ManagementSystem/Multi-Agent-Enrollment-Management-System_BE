{
  "ConnectionStrings": {
    "DefaultConnection": "User Id=YOUR_DB_USER;Password=YOUR_DB_PASSWORD;Server=YOUR_DB_HOST;Port=5432;Database=postgres"
  },
  "JwtSettings": {
    "SecretKey": "YOUR_JWT_SECRET_KEY_MIN_32_CHARS",
    "Issuer": "MAEMS_API",
    "Audience": "MAEMS_Client",
    "ExpiryInMinutes": 60,
    "RefreshTokenExpiryInDays": 7
  },
  "Firebase": {
    "ProjectId": "YOUR_FIREBASE_PROJECT_ID",
    "CredentialPath": "firebase-adminsdk.json",
    "StorageBucket": "YOUR_FIREBASE_STORAGE_BUCKET",
    "StorageCredentialPath": "firebase-storage-adminsdk.json"
  },
  "Email": {
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": "587",
    "FromEmail": "YOUR_EMAIL@gmail.com",
    "FromPassword": "YOUR_GMAIL_APP_PASSWORD",
    "FromName": "YOUR_APP_NAME"
  },
  "ApiBaseUrl": "https://YOUR_API_DOMAIN",
  "FrontendUrl": "https://YOUR_FRONTEND_DOMAIN/",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Ollama": {
    "ApiUrl": "https://YOUR_OLLAMA_API_URL/api/chat",
    "ApiKey": "YOUR_OLLAMA_API_KEY",
    "ModelName": "YOUR_OLLAMA_MODEL_NAME",
    "TimeoutSeconds": 300
  },
  "GeminiService": {
    "ApiKey": "YOUR_GEMINI_API_KEY",
    "ApiUrl": "https://generativelanguage.googleapis.com/v1beta/models",
    "ModelName": "gemini-flash-latest",
    "TimeoutSeconds": 60
  },
  "OpenAIService": {
    "ApiKey": "YOUR_OPENAI_API_KEY",
    "ChatModel": "gpt-4o-mini",
    "TimeoutSeconds": 30
  },
  "RagSettings": {
    "ChunkSizeTokens": 512,
    "ChunkOverlapTokens": 50,
    "DefaultTopK": 5,
    "MinSimilarityScore": 0.3,
    "EnableAutoIndexing": false,
    "IndexingIntervalMinutes": 60,
    "Qdrant": {
      "Url": "https://YOUR_QDRANT_CLUSTER_URL",
      "ApiKey": "YOUR_QDRANT_API_KEY",
      "CollectionName": "admission_documents",
      "VectorDimension": 3072,
      "VectorMetric": "cosine"
    },
    "Embedding": {
      "ModelName": "gemini-embedding-001",
      "TaskType": "SEMANTIC_SEARCH",
      "BatchSize": 5,
      "DelayBetweenRequestsMs": 500,
      "DelayBetweenBatchesMs": 1000
    }
  }
}
